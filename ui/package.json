{
  "name": "lonanote",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "workspaces": [
    "rust"
  ],
  "scripts": {
    "start": "cross-env APP_MODE=development expo start --dev-client",
    "android": "cross-env APP_MODE=development expo run:android --device",
    "ios": "cross-env APP_MODE=development expo run:ios --device",
    "web": "cross-env APP_MODE=development expo start --web",
    "web:ci": "cross-env APP_MODE=development CI=1 expo start --web",
    "build:android": "cross-env APP_MODE=production expo run:android --variant release --device",
    "build:ios": "cross-env APP_MODE=production expo run:ios --configuration Release --device",
    "build:android:ci": "cross-env APP_MODE=production CI=1 expo run:android --variant release",
    "build:ios:ci": "cross-env APP_MODE=production CI=1 expo run:ios --configuration Release",
    "build:web": "cross-env APP_MODE=production expo export --platform web",
    "build:web:sourcemap": "cross-env APP_MODE=production expo export --platform web --source-maps inline --no-minify",
    "build:web:dev": "cross-env APP_MODE=production expo export --platform web --dev",
    "noclean:prebuild:android": "cross-env APP_MODE=development expo prebuild --platform android",
    "noclean:prebuild:ios": "cross-env APP_MODE=development expo prebuild --platform ios",
    "noclean:prebuild:android:prod": "cross-env APP_MODE=production expo prebuild --platform android",
    "noclean:prebuild:ios:prod": "cross-env APP_MODE=production expo prebuild --platform ios",
    "clean:prebuild:android": "cross-env APP_MODE=development expo prebuild --clean --platform android",
    "clean:prebuild:ios": "cross-env APP_MODE=development expo prebuild --clean --platform ios",
    "clean:prebuild:android:prod": "cross-env APP_MODE=production expo prebuild --clean --platform android",
    "clean:prebuild:ios:prod": "cross-env APP_MODE=production expo prebuild --clean --platform ios",
    "build:check:android:dev": "cross-env APP_MODE=development node tools/build_check.cjs --android",
    "build:check:android:prod": "cross-env APP_MODE=production node tools/build_check.cjs --android",
    "build:check:ios:dev": "cross-env APP_MODE=development node tools/build_check.cjs --ios",
    "build:check:ios:prod": "cross-env APP_MODE=production node tools/build_check.cjs --ios",
    "build:check:prebuild:android:dev": "bun build:check:android:dev -- --prebuild",
    "build:check:prebuild:android:prod": "bun build:check:android:prod -- --prebuild",
    "build:check:prebuild:ios:dev": "bun build:check:ios:dev -- --prebuild",
    "build:check:prebuild:ios:prod": "bun build:check:ios:prod -- --prebuild",
    "build:check:postbuild:android:dev": "bun build:check:android:dev -- --postbuild",
    "build:check:postbuild:android:prod": "bun build:check:android:prod -- --postbuild",
    "build:check:postbuild:ios:dev": "bun build:check:ios:dev -- --postbuild",
    "build:check:postbuild:ios:prod": "bun build:check:ios:prod -- --postbuild",
    "generate:tamagui": "bunx @tamagui/cli generate",
    "lint": "bun run lint:eslint && bun run typecheck",
    "lint:eslint": "expo lint",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.10",
    "@react-native-menu/menu": "2.0.0",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/elements": "^2.9.15",
    "@react-navigation/native": "^7.2.2",
    "@tamagui/config": "=2.1.0",
    "@tamagui/lucide-icons-2": "=2.1.0",
    "@tamagui/toast": "=2.1.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "clsx": "^2.1.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "expo": "~55.0.18",
    "expo-build-properties": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-device": "~55.0.15",
    "expo-file-system": "~55.0.17",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.9",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "globals": "^17.5.0",
    "lonanote_rust_module": "workspace:*",
    "prettier": "^3.8.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.83.9",
    "react-native-gesture-handler": "=2.31.1",
    "react-native-ios-context-menu": "^3.2.1",
    "react-native-ios-utilities": "5.2.0",
    "react-native-reanimated": "=4.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-teleport": "^1.1.7",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "=0.8.1",
    "tamagui": "=2.1.0",
    "typescript-eslint": "^8.59.1",
    "zeego": "^3.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@eslint/js": "^10.0.1",
    "@expo/config-plugins": "^55.0.8",
    "@tamagui/babel-plugin": "=2.1.0",
    "@types/react": "~19.2.5",
    "babel-preset-expo": "^55.0.20",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "@react-native-menu/menu": "2.0.0",
    "metro": "=0.83.6",
    "metro-babel-transformer": "=0.83.6",
    "metro-cache": "=0.83.6",
    "metro-cache-key": "=0.83.6",
    "metro-config": "=0.83.6",
    "metro-core": "=0.83.6",
    "metro-file-map": "=0.83.6",
    "metro-minify-terser": "=0.83.6",
    "metro-resolver": "=0.83.6",
    "metro-runtime": "=0.83.6",
    "metro-source-map": "=0.83.6",
    "metro-symbolicate": "=0.83.6",
    "metro-transform-plugins": "=0.83.6",
    "metro-transform-worker": "=0.83.6"
  },
  "patchedDependencies": {
    "@tamagui/toast@2.1.0": "patches/@tamagui+toast@2.1.0.patch",
    "metro-file-map@0.83.6": "patches/metro-file-map@0.83.6.patch",
    "metro@0.83.6": "patches/metro@0.83.6.patch",
    "react-native-reanimated@4.3.0": "patches/react-native-reanimated@4.3.0.patch"
  }
}