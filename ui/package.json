{
  "name": "lonanote",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "workspaces": [
    "rust"
  ],
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "start:prod": "expo start --no-dev --minify",
    "build:android": "expo run:android --variant release",
    "build:ios": "expo run:ios --configuration Release",
    "build:web": "expo export --platform web",
    "prebuild": "cross-env APP_VARIANT=development expo prebuild --clean",
    "prebuild:android": "cross-env APP_VARIANT=development expo prebuild --clean --platform android",
    "prebuild:ios": "cross-env APP_VARIANT=development expo prebuild --clean --platform ios",
    "prebuild:prod": "expo prebuild --clean",
    "prebuild:android:prod": "expo prebuild --clean --platform android",
    "prebuild:ios:prod": "expo prebuild --clean --platform ios",
    "lint": "expo lint"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.10",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/elements": "^2.9.15",
    "@react-navigation/native": "^7.2.2",
    "@tauri-apps/api": "^2.11.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "expo": "~55.0.18",
    "expo-constants": "~55.0.15",
    "expo-device": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-image": "~55.0.9",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "globals": "^17.5.0",
    "heroui-native": "^1.0.2",
    "lonanote_rust_module": "workspace:*",
    "prettier": "^3.8.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.83.9",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "typescript-eslint": "^8.59.1",
    "uniwind": "^1.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@expo/config-plugins": "^55.0.8",
    "@types/react": "~19.2.5",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
