{
  "name": "lonanote",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "workspaces": [
    "rust"
  ],
  "scripts": {
    "start": "node tools/build/build.cjs start",
    "android": "node tools/build/build.cjs dev:android",
    "ios": "node tools/build/build.cjs dev:ios",
    "web": "node tools/build/build.cjs dev:web",
    "web:ci": "node tools/build/build.cjs dev:web --ci",
    "build:android": "node tools/build/build.cjs build:android",
    "build:android:ci": "node tools/build/build.cjs build:android --ci",
    "build:ios": "node tools/build/build.cjs build:ios",
    "build:ios:ci": "node tools/build/build.cjs build:ios --ci",
    "build:web": "node tools/build/build.cjs build:web",
    "build:web:sourcemap": "node tools/build/build.cjs build:web --sourcemap",
    "build:web:dev": "node tools/build/build.cjs build:web --dev",
    "android:check:dev": "node tools/build/build_check.cjs --android --dev",
    "android:check:prod": "node tools/build/build_check.cjs --android --prod",
    "ios:check:dev": "node tools/build/build_check.cjs --ios --dev",
    "ios:check:prod": "node tools/build/build_check.cjs --ios --prod",
    "android:prebuild": "node tools/build/prebuild.cjs android both",
    "android:prebuild:dev": "node tools/build/prebuild.cjs android dev",
    "android:prebuild:prod": "node tools/build/prebuild.cjs android prod",
    "ios:prebuild": "node tools/build/prebuild.cjs ios both",
    "ios:prebuild:dev": "node tools/build/prebuild.cjs ios dev",
    "ios:prebuild:prod": "node tools/build/prebuild.cjs ios prod",
    "generate:tamagui": "bunx @tamagui/cli generate",
    "sync:sdk-config": "node tools/sync_android_sdk_config.cjs",
    "lint": "bun run lint:eslint && bun run typecheck",
    "lint:eslint": "expo lint",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.14",
    "@lodev09/react-native-true-sheet": "^3.10.1",
    "@react-native-menu/menu": "2.0.0",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/elements": "^2.9.19",
    "@react-navigation/native": "^7.2.5",
    "@tamagui/config": "=2.1.0",
    "@tamagui/lucide-icons-2": "=2.1.0",
    "@tamagui/toast": "=2.1.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "clsx": "^2.1.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "expo": "~56.0.8",
    "expo-build-properties": "~56.0.16",
    "expo-constants": "~56.0.16",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "globals": "^17.6.0",
    "lonanote_rust_module": "workspace:*",
    "prettier": "^3.8.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "=2.31.2",
    "react-native-ios-context-menu": "^3.2.1",
    "react-native-ios-utilities": "github:dominicstop/react-native-ios-utilities#e520d1a64b2d",
    "react-native-reanimated": "=4.4.0",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "=4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-teleport": "^1.1.7",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "=0.9.1",
    "tamagui": "=2.1.0",
    "typescript-eslint": "^8.59.1",
    "zeego": "^3.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@eslint/js": "^10.0.1",
    "@expo/config-plugins": "^56.0.8",
    "@tamagui/babel-plugin": "=2.1.0",
    "@types/react": "~19.2.16",
    "babel-preset-expo": "^56.0.14",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "expo-modules-core": "56.0.13",
    "metro": "=0.84.4",
    "metro-babel-transformer": "=0.84.4",
    "metro-cache": "=0.84.4",
    "metro-cache-key": "=0.84.4",
    "metro-config": "=0.84.4",
    "metro-core": "=0.84.4",
    "metro-file-map": "=0.84.4",
    "metro-minify-terser": "=0.84.4",
    "metro-resolver": "=0.84.4",
    "metro-runtime": "=0.84.4",
    "metro-source-map": "=0.84.4",
    "metro-symbolicate": "=0.84.4",
    "metro-transform-plugins": "=0.84.4",
    "metro-transform-worker": "=0.84.4"
  },
  "patchedDependencies": {
    "@tamagui/dialog@2.1.0": "patches/@tamagui+dialog@2.1.0.patch",
    "@tamagui/native@2.1.0": "patches/@tamagui+native@2.1.0.patch",
    "@tamagui/portal@2.1.0": "patches/@tamagui+portal@2.1.0.patch",
    "@tamagui/toast@2.1.0": "patches/@tamagui+toast@2.1.0.patch",
    "@expo/metro-file-map@56.0.3": "patches/@expo+metro-file-map@56.0.3.patch",
    "metro-file-map@0.84.4": "patches/metro-file-map@0.84.4.patch",
    "metro@0.84.4": "patches/metro@0.84.4.patch",
    "react-native-reanimated@4.4.0": "patches/react-native-reanimated@4.4.0.patch",
    "@tamagui/web@2.1.0": "patches/@tamagui+web@2.1.0.patch"
  }
