  "scripts": {
    "start": "node tools/build/build.cjs start",
    "android": "node tools/build/build.cjs dev:android",
    "ios": "node tools/build/build.cjs dev:ios",
    "web": "node tools/build/build.cjs dev:web",
    "web:ci": "node tools/build/build.cjs dev:web --ci",
    "build:android": "node tools/build/build.cjs build:android",
    "build:android:ci": "node tools/build/build.cjs build:android --ci",
