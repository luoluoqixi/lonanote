{
  "name": "lonanote",
  "version": "2.0.0-rc.41-1776813063972",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "upgrade:tamagui": "bunx npm-check-updates -u '*tamagui*' '@tamagui/*' && bun install",
    "start": "bunx expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "start:prod": "expo start --no-dev --minify",
    "build:android": "expo run:android --variant release",
    "build:ios": "expo run:ios --configuration Release",
    "build:web": "expo export --platform web",
    "prebuild:android": "expo prebuild --platform android",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:clean": "expo prebuild --clean",
    "generate:tamagui": "bunx @tamagui/cli generate"
  },
  "dependencies": {
    "@tamagui/config": "^2.0.0-rc.41",
    "@tamagui/lucide-icons-2": "^2.0.0-rc.41",
    "@tamagui/toast": "^2.0.0-rc.41",
    "babel-preset-expo": "~55.0.0",
    "burnt": "^0.12.2",
    "expo": "~55.0.6",
    "expo-build-properties": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "lonanote_ui_core": "link:lonanote_ui_core",
    "react": ">=19",
    "react-dom": "*",
    "react-native": "0.83.2",
    "react-native-reanimated": "~4.2.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "tamagui": "^2.0.0-rc.41"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/metro-runtime": "~55.0.6",
    "@tamagui/babel-plugin": "^2.0.0-rc.41",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "serve": "^14.2.5",
    "typescript": "~5.9.2"
  },
  "packageManager": "bun@1.3.9"
}
