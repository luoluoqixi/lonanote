    "build:web:dev": "node tools/build/build.cjs build:web --dev",
    "android:prebuild": "node tools/build/prebuild.cjs android both",
    "android:prebuild:dev": "node tools/build/prebuild.cjs android dev",
    "android:prebuild:prod": "node tools/build/prebuild.cjs android prod",
    "ios:prebuild": "node tools/build/prebuild.cjs ios both",
    "ios:prebuild:dev": "node tools/build/prebuild.cjs ios dev",
    "ios:prebuild:prod": "node tools/build/prebuild.cjs ios prod",
