{
  "name": "lonanote_rust_module",
  "version": "0.1.0",
  "description": "lonanote_rust_module",
  "author": "luoluoqixi",
  "homepage": "https://github.com/luoluoqixi/lonanote",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "prepack": "yarn build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "build:android": "node ./scripts/build.mjs android",
    "build:ios": "node ./scripts/build.mjs ios",
    "clean": "bun x craby clean",
    "generate": "bun x crabygen"
  },
  "dependencies": {
    "craby-modules": "^0.1.0-rc.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.7",
    "@react-native-community/cli-types": "^20.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "crabygen": "^0.1.0-rc.5",
    "tsdown": "^0.15.10",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  }
}
