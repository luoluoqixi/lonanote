{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "app.config.ts",
    "tamagui.build.ts",
    "tamagui.config.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    ".expo",
    ".tamagui",
    "android",
    "ios",
    "node_modules",
    "dist",
    "android",
    "rust/.build-cache",
    "rust/android",
    "rust/ios",
    "rust/crates",
    "rust/dist",
    "rust/target",
  ]
}
